# When opening the dev UI by LAN IP (not localhost), requests go directly to the backend URL:
# VITE_API_URL=http://192.168.x.x:3001
# Optional — defaults to http://<current-host>:3001
VITE_API_URL=http://localhost:3001

# Timezone Configuration (must match backend DB_TIMEZONE)
VITE_COMPANY_TIMEZONE=Australia/Melbourne
